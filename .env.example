APP_NAME="A1 Training Group"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-railway-url.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# MongoDB (optional — falls back to SQLite if not set)
DB_CONNECTION=sqlite
MONGODB_URI=
MONGO_DB_DATABASE=a1training

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file
RESPONSE_CACHE_ENABLED=true

# Stripe (for future e-commerce)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
MAIL_FROM_ADDRESS=info@a1traininggroupllc.com
MAIL_FROM_NAME="A1 Training Group"

# Admin access
ADMIN_EMAILS=admin@a1traininggroupllc.com
ADMIN_INITIAL_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# Google Tag Manager
GTM_ID=
GA_MEASUREMENT_ID=
